.Lg, .Btn, .BtnC, .Input
  display flex
  position relative
  z-index 1

.Lg::before, .Btn::before, .BtnC::before, .Input::before
  backdrop-filter blur(8px) saturate(150%) var(--glassSvg)
  border-radius inherit
  content ''
  inset 0
  position absolute
  transition background 0.3s cubic-bezier(0.4, 0, 0.2, 1)
  z-index -1

.Lg::before, .Input::before
  background linear-gradient(180deg, #f5f5f54d, #f5f5f580)

.Btn::before, .BtnC::before
  background var(--btnBg)

.Lg::after, .Btn::after, .BtnC::after, .Input::after
  background-clip border-box
  background-image linear-gradient(180deg, #0000004d, #00000026)
  background-origin border-box
  border 1px solid transparent
  border-radius inherit
  border-width 0.5px
  content ''
  inset 0
  mask-clip content-box, border-box
  mask-composite exclude
  mask-image linear-gradient(#fff 0 0), linear-gradient(#fff 0 0)
  pointer-events none
  position absolute
  z-index -1

main.Lg
  border-radius 24px
  margin var(--gap)
  padding var(--gap)
  text-align center