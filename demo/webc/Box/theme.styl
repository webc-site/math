dialog.Box
  background transparent
  border none
  bottom 0
  left 0
  margin auto
  max-width min(calc(100vw - 32px), 360px)
  outline none
  overflow visible
  padding 0
  position fixed
  right 0
  top 0
  width 100%
  z-index 2147483647

  &[open]
    animation BoxShow 0.35s cubic-bezier(0.16, 1, 0.3, 1)

  &>.Lg
    align-items stretch
    background-color #fffffff2
    border-radius 24px
    box-shadow 0 20px 40px #0000001a, 0 1px 3px #00000005
    box-sizing border-box
    display flex
    flex-direction column
    gap 20px
    margin 0 auto
    padding 32px 28px
    text-align center

    h3
      color #1d1d1f
      font-size 20px
      font-weight 600
      line-height 1.4
      margin 0

    p
      color #6e6e73
      font-size 14px
      font-weight 400
      line-height 1.5
      margin 0

  &::backdrop
    animation BoxBackdropShow 0.35s cubic-bezier(0.16, 1, 0.3, 1)
    backdrop-filter blur(4px)
    background-color #0000004d

@keyframes BoxShow
  from
    opacity 0
    transform scale(0.96) translate3d(0, 8px, 0)

  to
    opacity 1
    transform scale(1) translate3d(0, 0, 0)

@keyframes BoxBackdropShow
  from
    opacity 0

  to
    opacity 1